{
  "name": "tauri-plugin-axum-api",
  "version": "0.7.2",
  "author": "mcitem",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcitem/tauri-plugin-axum.git"
  },
  "description": "Call your Axum router directly — just like a local database, not a remote server.",
  "keywords": [
    "tauri-plugin",
    "axum"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "prepack": "rollup -c && shx rm README.md && shx cp tauri-plugin-axum/README.md ./README.md",
    "postpack": "shx rm README.md && shx ln -s tauri-plugin-axum/README.md ./README.md"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1"
  },
  "peerDependencies": {
    "axios": "^1"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "rollup": "^4.60.1",
    "rollup-plugin-copy": "^3.5.0",
    "shx": "^0.4.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}